{
  "version": 1,
  "id": "starter-demo-pack",
  "title": "Starter Demo Pack",
  "commands": [
    {
      "name": "roadmap",
      "description": "Show the next milestones",
      "aliases": ["plan"],
      "response": {
        "lines": [
          { "type": "info", "value": "Q2 roadmap" },
          { "type": "out", "value": "  1. Ship onboarding v2" },
          { "type": "out", "value": "  2. Add analytics dashboard" },
          { "type": "out", "value": "  3. Launch invite-only beta" }
        ]
      },
      "quickAction": {
        "label": "roadmap",
        "command": "roadmap"
      }
    },
    {
      "name": "status-check",
      "description": "Stream a virtual status check",
      "response": {
        "stream": [
          { "kind": "status", "value": "Collecting workspace state...", "delayMs": 120 },
          { "kind": "line", "line": { "type": "out", "value": "cwd: {{cwd}}" }, "delayMs": 120 },
          { "kind": "line", "line": { "type": "out", "value": "history size: {{historyCount}}" }, "delayMs": 90 },
          { "kind": "line", "line": { "type": "success", "value": "Ready for next task: {{args}}" }, "delayMs": 130 }
        ]
      },
      "quickAction": {
        "label": "status-check",
        "command": "status-check review auth flow"
      }
    },
    {
      "name": "wipe-output",
      "description": "Clear terminal output",
      "response": {
        "lines": []
      },
      "clearBefore": true,
      "quickAction": {
        "label": "wipe-output",
        "command": "wipe-output"
      }
    }
  ]
}
